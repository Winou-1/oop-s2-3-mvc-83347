@model VgcCollege.Web.Domain.ExamResult

@{
    ViewData["Title"] = "Add Exam Result";
}

<h1>Add Exam Result</h1>
<hr />

<div class="row">
    <div class="col-md-4">
        <form asp-action="AddResult">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="ExamId" />

            <div class="form-group mb-3">
                <label asp-for="StudentProfileId" class="control-label"></label>
                <select asp-for="StudentProfileId" class="form-control" asp-items="ViewBag.StudentProfileId">
                    <option value="">— Select Student —</option>
                </select>
                <span asp-validation-for="StudentProfileId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Score" class="control-label"></label>
                <input asp-for="Score" class="form-control" />
                <span asp-validation-for="Score" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Grade" class="control-label"></label>
                <input asp-for="Grade" class="form-control" placeholder="e.g. A, B, C, F" />
                <span asp-validation-for="Grade" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Save Result" class="btn btn-primary" />
                <a asp-action="Details" asp-route-id="@Model.ExamId" class="btn btn-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
