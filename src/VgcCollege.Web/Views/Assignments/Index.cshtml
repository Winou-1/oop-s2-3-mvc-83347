@model IEnumerable<VgcCollege.Web.Domain.Assignment>

@{
    ViewData["Title"] = "Assignments";
    bool isAdmin = User.IsInRole("Admin");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Assignments</h1>
    @if (isAdmin)
    {
        <a asp-action="Create" class="btn btn-success">+ New Assignment</a>
    }
</div>

<table class="table table-hover">
    <thead class="table-dark">
        <tr>
            <th>Course</th>
            <th>Branch</th>
            <th>Title</th>
            <th>Max Score</th>
            <th>Due Date</th>
            <th>Results</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <a asp-controller="Courses" asp-action="Details" asp-route-id="@item.CourseId">
                        @item.Course?.Name
                    </a>
                </td>
                <td>@item.Course?.Branch?.Name</td>
                <td>@item.Title</td>
                <td>@item.MaxScore</td>
                <td>
                    @{
                        var overdue = item.DueDate < DateTime.Today;
                    }
                    <span class="@(overdue ? "text-danger" : "")">@item.DueDate.ToShortDateString()</span>
                </td>
                <td><span class="badge bg-primary">@item.Results.Count</span></td>
                <td class="d-flex gap-1">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                    @if (isAdmin)
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
