@model IEnumerable<VgcCollege.Web.Domain.CourseEnrolment>
@using VgcCollege.Web.Domain

@{
    ViewData["Title"] = User.IsInRole("Student") ? "My Courses" : "Enrolments";
    bool isAdmin = User.IsInRole("Admin");
    bool isStudent = User.IsInRole("Student");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>@ViewData["Title"]</h1>
    @if (isAdmin)
    {
        <a asp-action="Create" class="btn btn-success">+ New Enrolment</a>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No enrolments found.</div>
}
else
{
    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                @if (!isStudent)
                {
                    <th>Student</th>
                }
                <th>Course</th>
                <th>Branch</th>
                <th>Enrolled</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    @if (!isStudent)
                    {
                        <td>@item.StudentProfile?.Name</td>
                    }
                    <td>
                        <a asp-controller="Courses" asp-action="Details" asp-route-id="@item.CourseId">
                            @item.Course?.Name
                        </a>
                    </td>
                    <td>@item.Course?.Branch?.Name</td>
                    <td>@item.EnrolDate.ToShortDateString()</td>
                    <td>
                        <span class="badge @(item.Status == EnrolmentStatus.Active ? "bg-success" : "bg-secondary")">
                            @item.Status
                        </span>
                    </td>
                    <td class="d-flex gap-1">
                        <a asp-controller="Attendance" asp-action="Index" asp-route-enrolmentId="@item.Id"
                           class="btn btn-sm btn-outline-info">Attendance</a>
                        @if (isAdmin)
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Remove</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
