@model IEnumerable<VgcCollege.Web.Domain.StudentProfile>

@{
    ViewData["Title"] = User.IsInRole("Faculty") ? "My Students" : "Students";
    bool isAdmin = User.IsInRole("Admin");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>@ViewData["Title"]</h1>
    @if (isAdmin)
    {
        <a asp-action="Create" class="btn btn-success">+ New Student</a>
    }
</div>

<table class="table table-hover">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Student No.</th>
            <th>Email</th>
            <th>Phone</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><strong>@item.Name</strong></td>
                <td><code>@item.StudentNumber</code></td>
                <td>@item.Email</td>
                <td>@(item.Phone ?? "—")</td>
                <td class="d-flex gap-1">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                    @if (isAdmin)
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
